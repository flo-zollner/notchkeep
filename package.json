{
  "name": "notchkeep",
  "version": "0.2.3",
  "description": "Notchkeep — Simple Personal Networth",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:mock": "vite dev --mode mock",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "gen:licenses": "cd src-tauri && cargo about generate about.hbs -o ../static/licenses.html && cd .. && node scripts/append-js-licenses.mjs",
    "gen:licenses:check": "cd src-tauri && cargo about generate about.hbs -o /dev/null",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "scan:pii": "bash scripts/scan-pii.sh",
    "scan:versions": "node scripts/check-versions.mjs",
    "scan:capabilities": "node scripts/audit-capabilities.mjs",
    "scan:secrets-committed": "bash scripts/check-secrets-committed.sh",
    "scan:update-endpoint": "node scripts/check-update-endpoint.mjs",
    "deny": "cd src-tauri && cargo deny check",
    "sbom": "cargo cyclonedx --manifest-path src-tauri/Cargo.toml -f json && cyclonedx-npm --output-file sbom-npm.json"
  },
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.0",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-plugin-svelte": "^3.19.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.7.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
