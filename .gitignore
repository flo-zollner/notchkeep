.DS_Store
.idea/
*.swp
*.swo
*~

# Node / SvelteKit / Vite
node_modules
/build
/.svelte-kit
/package
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Env-Dateien (Geheimnisse)
.env
.env.*
!.env.example

# Echte Bewegungsdaten – nie ins Repo
/test-material/

# Dev-DBs und SQLite-Snapshots (Syncthing-synchronisiert, enthalten PII)
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
budget.sqlite*

# Logs und Crash-Dumps
*.log
*.log.*
crash-*.dmp

# Screenshots / Anhänge (können Realdaten enthalten)
*.screenshot.png
pasted*.png
pasted file.*

# Backup-Verzeichnisse (z. B. .git.backup-*)
*.backup-*
*.bak
*-backup/

# Rust / Tauri Build-Output
/src-tauri/target/

# cargo-mutants Output (lokal, nicht ins Repo)
/src-tauri/mutants.out/
/src-tauri/mutants.out.old/

# Tauri Signing Keys (NIE committen!)
*.tauri.key
*.signing-key
.tauri-keystore/
/src-tauri/*.jks
/src-tauri/*.keystore

# Tauri Mobile auto-generierter Gradle-Projekt-Ordner.
# gen/* ignorieren (statt gen/), damit die Ausnahme für gen/android greift —
# ein komplett ignoriertes Elternverzeichnis lässt sich sonst nicht re-includen.
/src-tauri/gen/*
# Ausnahme: gen/android wird committet (persistente native Config: signing,
# minSdk, Plugin-Manifest). Secrets und Build-Output bleiben ignoriert.
!/src-tauri/gen/android/
/src-tauri/gen/android/.gradle/
/src-tauri/gen/android/build/
/src-tauri/gen/android/app/build/
/src-tauri/gen/android/.cxx/
/src-tauri/gen/android/local.properties
/src-tauri/gen/android/keystore.properties
/src-tauri/gen/android/**/*.jks
/src-tauri/gen/android/**/*.keystore

# Sonstige lokale Notizen
/further
/further.save

# Claude Code lokale Settings und State (Memory liegt bewusst in ~/.claude/)
.claude/
.claude/settings.local.json
/CLAUDE.md

# Brainstorming Companion Mockups
.superpowers/

# Playwright MCP Artefakte (Snapshots, Screenshots, Console-Logs)
.playwright-mcp/

# Playwright E2E test results and reports (generated, not source)
/test-results/
/playwright-report/
